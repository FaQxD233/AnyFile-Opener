<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="content" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="file" />
        </intent>
        <!-- Discover file managers that handle directory documents -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="vnd.android.document/directory" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="resource/folder" />
        </intent>
        <intent>
            <action android:name="android.provider.action.BROWSE" />
        </intent>
        <intent>
            <action android:name="android.provider.action.BROWSE_DOCUMENT_ROOT" />
        </intent>
        <package android:name="com.android.documentsui" />
        <package android:name="com.google.android.documentsui" />
    </queries>

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher_round"
        android:label="AnyFile Opener"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenBridge.Transparent">

        <activity
            android:name="com.anyfile.x.LauncherActivity"
            android:exported="true"
            android:label="AnyFile Opener"
            android:theme="@style/Theme.OpenBridge.Launcher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name="com.anyfile.x.MainActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.OpenBridge.Transparent">

            <intent-filter android:priority="1">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="*/*" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.anyfile.x.SettingsActivity"
            android:exported="false"
            android:label="Settings"
            android:theme="@style/Theme.OpenBridge.Launcher" />

        <receiver
            android:name="com.anyfile.x.widget.FolderWidgetProvider"
            android:exported="false"
            android:label="Android Folder Shortcut">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.anyfile.x.action.OPEN_FOLDER" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/folder_widget_info" />
        </receiver>

        <receiver
            android:name="com.anyfile.x.routing.ChooserResultReceiver"
            android:exported="false" />

    </application>

</manifest>
