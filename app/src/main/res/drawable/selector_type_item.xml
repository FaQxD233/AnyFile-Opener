<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected / Auto-detected state -->
    <item android:state_selected="true">
        <shape>
            <solid android:color="#26E08EFE" />
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="@color/primary" />
        </shape>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/glass_white_10" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Normal state -->
    <item>
        <shape>
            <solid android:color="@color/surface_container_highest" />
            <corners android:radius="16dp" />
            <stroke android:width="1dp" android:color="@color/outline_variant" />
        </shape>
    </item>

</selector>
