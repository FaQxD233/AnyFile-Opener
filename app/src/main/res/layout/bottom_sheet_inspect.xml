<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="20dp"
        android:background="#50505A" />

    <!-- Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:src="@android:drawable/ic_menu_view"
            android:tint="#8B7FD4" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Binary Inspector"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- File info card -->
    <LinearLayout
        android:id="@+id/fileInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="#1A1A2E"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="FILE"
                android:textColor="#9090A0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/inspectFileName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="middle"
                android:maxLines="1"
                android:text="..."
                android:textColor="#FFFFFF"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="MIME"
                android:textColor="#9090A0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/inspectMimeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="..."
                android:textColor="#8B7FD4"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="SIZE"
                android:textColor="#9090A0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/inspectSizeText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="..."
                android:textColor="#CCCCCC"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Hex label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:text="HEX DUMP"
            android:textColor="#9090A0"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hexByteCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(first 256 bytes)"
            android:textColor="#606070"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Hex dump display -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:scrollbars="horizontal">

        <TextView
            android:id="@+id/hexDumpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#111118"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:text="Loading..."
            android:textColor="#90EE90"
            android:textSize="11sp" />
    </HorizontalScrollView>

    <!-- ASCII dump label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="ASCII PREVIEW"
        android:textColor="#9090A0"
        android:textSize="10sp"
        android:textStyle="bold" />

    <!-- ASCII preview -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:scrollbars="horizontal">

        <TextView
            android:id="@+id/asciiDumpText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#111118"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="12dp"
            android:text="Loading..."
            android:textColor="#FFD700"
            android:textSize="11sp" />
    </HorizontalScrollView>

</LinearLayout>
